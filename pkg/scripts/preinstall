#!/bin/bash
# Claw Web — preinstall: 인증번호 확인 + Node.js 체크
set -e

# 한글 깨짐 방지
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LANGUAGE=en_US.UTF-8

LOG="/tmp/claw-web-install.log"
echo "[preinstall] $(date)" >> "$LOG"

# ═══════════════════════════════════════════════
# 1. 인증번호 입력 + Google Sheets A열 대조
# ═══════════════════════════════════════════════
# 공개된 CSV URL 에서 A열 값들 fetch → 입력값이 포함되는지 확인.
# 네트워크 실패 시에는 공란만 거부하는 fallback 모드로 전환.

LICENSE_CSV_URL="https://docs.google.com/spreadsheets/d/e/2PACX-1vQMglOPUJkiMKJ7e7T8CbyA9vMoN8YjWTDfmZFKAQ3VEkM5zPhyu5pKyoKpKyv494rBuDiXG-ozmBCE/pub?gid=0&single=true&output=csv"

# 1-1) 시트 fetch (10초 타임아웃)
VALID_CODES=""
FETCH_OK=0
if VALID_CODES=$(curl -sL --max-time 10 "$LICENSE_CSV_URL" 2>/dev/null); then
  # CSV 의 각 줄에서 첫 칼럼만 추출, 공백/CR 제거, 빈 라인 제외
  VALID_CODES=$(echo "$VALID_CODES" \
    | awk -F',' '{print $1}' \
    | tr -d '\r' \
    | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); if ($0 != "") print}')
  if [ -n "$VALID_CODES" ]; then
    FETCH_OK=1
    CODE_COUNT=$(echo "$VALID_CODES" | wc -l | tr -d ' ')
    echo "[preinstall] license sheet fetched: $CODE_COUNT codes" >> "$LOG"
  fi
fi

if [ "$FETCH_OK" != "1" ]; then
  echo "[preinstall] license sheet fetch failed — fallback to empty-only rejection" >> "$LOG"
fi

# 1-2) 인증번호 입력 다이얼로그 (재시도 3회)
MAX_ATTEMPTS=3
ATTEMPT=1
LICENSE_OK=0

while [ "$ATTEMPT" -le "$MAX_ATTEMPTS" ] && [ "$LICENSE_OK" = "0" ]; do
  if [ "$FETCH_OK" = "1" ]; then
    PROMPT_MSG="Claw Web 설치 인증번호를 입력하세요.

시트에 등록된 인증번호 중 하나를 입력해주세요.
시도 $ATTEMPT/$MAX_ATTEMPTS"
  else
    PROMPT_MSG="Claw Web 설치 인증번호를 입력하세요.
(오프라인 — 공란만 거부됩니다)

시도 $ATTEMPT/$MAX_ATTEMPTS"
  fi

  LICENSE=$(osascript 2>/dev/null <<OSA
try
  set dlg to display dialog "$PROMPT_MSG" default answer "" with title "Claw Web — 인증번호 확인" buttons {"취소", "설치 계속"} default button 2 with icon note
  return text returned of dlg
on error
  return "__CANCELLED__"
end try
OSA
)

  if [ "$LICENSE" = "__CANCELLED__" ]; then
    osascript -e 'display dialog "설치가 취소되었습니다." buttons {"확인"} default button 1 with icon stop with title "Claw Web"' 2>/dev/null || true
    echo "[preinstall] FAILED: user cancelled" >> "$LOG"
    exit 1
  fi

  # trim
  LICENSE_TRIM=$(echo "$LICENSE" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

  if [ -z "$LICENSE_TRIM" ]; then
    osascript -e 'display dialog "인증번호를 비울 수 없습니다." buttons {"다시 입력"} default button 1 with icon stop with title "Claw Web"' 2>/dev/null || true
    ATTEMPT=$((ATTEMPT + 1))
    continue
  fi

  if [ "$FETCH_OK" = "1" ]; then
    # 시트 A열 중 하나와 정확히 일치하는지 체크 (case-sensitive)
    if echo "$VALID_CODES" | grep -Fxq "$LICENSE_TRIM"; then
      LICENSE_OK=1
    else
      osascript -e "display dialog \"입력한 인증번호가 시트에 없습니다.\n다시 입력해주세요.\" buttons {\"다시 입력\"} default button 1 with icon stop with title \"Claw Web\"" 2>/dev/null || true
      ATTEMPT=$((ATTEMPT + 1))
    fi
  else
    # 오프라인 fallback: 공란만 아니면 통과
    LICENSE_OK=1
  fi
done

if [ "$LICENSE_OK" != "1" ]; then
  osascript -e "display dialog \"인증번호 확인에 $MAX_ATTEMPTS 회 실패했습니다.\n설치를 중단합니다.\" buttons {\"확인\"} default button 1 with icon stop with title \"Claw Web\"" 2>/dev/null || true
  echo "[preinstall] FAILED: license mismatch after $MAX_ATTEMPTS attempts" >> "$LOG"
  exit 1
fi

# 통과한 인증번호 기록
mkdir -p /var/db 2>/dev/null || true
echo "$LICENSE_TRIM" > /var/db/claw-web-license.txt 2>/dev/null || true
chmod 644 /var/db/claw-web-license.txt 2>/dev/null || true
echo "[preinstall] license OK (fetched=$FETCH_OK, len=${#LICENSE_TRIM})" >> "$LOG"

# ═══════════════════════════════════════════════
# 2. Node.js 확인
# ═══════════════════════════════════════════════
NODE_PATH=""

# 일반 경로 탐색
for p in \
  /usr/local/bin/node \
  /opt/homebrew/bin/node \
  /opt/homebrew/opt/node/bin/node \
  /opt/homebrew/opt/node@22/bin/node \
  /opt/homebrew/opt/node@20/bin/node \
  /usr/local/opt/node@22/bin/node \
  /usr/local/opt/node@20/bin/node; do
  if [ -x "$p" ]; then NODE_PATH="$p"; break; fi
done

# nvm 경로 탐색 (설치된 가장 최신 버전)
if [ -z "$NODE_PATH" ]; then
  REAL_USER_NVM=$(stat -f '%Su' /dev/console 2>/dev/null || echo "${SUDO_USER:-}")
  NVM_DIR_CANDIDATES="/Users/$REAL_USER_NVM/.nvm /root/.nvm"
  for nvm_dir in $NVM_DIR_CANDIDATES; do
    if [ -d "$nvm_dir/versions/node" ]; then
      NVM_NODE=$(ls -1 "$nvm_dir/versions/node" 2>/dev/null | sort -V | tail -1)
      if [ -n "$NVM_NODE" ] && [ -x "$nvm_dir/versions/node/$NVM_NODE/bin/node" ]; then
        NODE_PATH="$nvm_dir/versions/node/$NVM_NODE/bin/node"
        break
      fi
    fi
  done
fi

# volta 경로 탐색
if [ -z "$NODE_PATH" ]; then
  REAL_USER_VOLTA=$(stat -f '%Su' /dev/console 2>/dev/null || echo "${SUDO_USER:-}")
  VOLTA_NODE="/Users/$REAL_USER_VOLTA/.volta/bin/node"
  if [ -x "$VOLTA_NODE" ]; then
    NODE_PATH="$VOLTA_NODE"
  fi
fi

if [ -z "$NODE_PATH" ]; then
  # Homebrew 있으면 자동 설치 제안
  BREW_PATH=""
  for bp in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$bp" ]; then BREW_PATH="$bp"; break; fi
  done

  if [ -n "$BREW_PATH" ]; then
    AUTO_INSTALL=$(osascript 2>/dev/null <<OSA
try
  set dlg to display dialog "Node.js가 설치되어 있지 않습니다.
Homebrew로 자동 설치할까요?" buttons {"취소", "자동 설치"} default button 2 with icon note with title "Claw Web — Node.js 필요"
  return button returned of dlg
on error
  return "취소"
end try
OSA
)
    if [ "$AUTO_INSTALL" = "자동 설치" ]; then
      REAL_USER_PRE=$(stat -f '%Su' /dev/console 2>/dev/null || echo "$SUDO_USER")
      echo "[preinstall] brewing node@22 as $REAL_USER_PRE..." >> "$LOG"
      su "$REAL_USER_PRE" -c "/opt/homebrew/bin/brew install node@22" 2>> "$LOG" || \
        su "$REAL_USER_PRE" -c "/usr/local/bin/brew install node@22" 2>> "$LOG" || true
      # 설치 후 재확인
      for p in /opt/homebrew/bin/node /usr/local/bin/node /opt/homebrew/opt/node@22/bin/node; do
        if [ -x "$p" ]; then NODE_PATH="$p"; break; fi
      done
      if [ -z "$NODE_PATH" ]; then
        osascript -e 'display dialog "Node.js 자동 설치에 실패했습니다.\nhttps://nodejs.org 에서 수동으로 설치 후 다시 실행해주세요." buttons {"확인"} default button 1 with icon stop with title "Claw Web"' 2>/dev/null || true
        echo "[preinstall] FAILED: brew install node@22 failed" >> "$LOG"
        exit 1
      fi
    else
      echo "[preinstall] FAILED: user cancelled Node.js auto-install" >> "$LOG"
      exit 1
    fi
  else
    # Homebrew 없음 → nodejs.org 열기
    osascript -e 'display dialog "Node.js가 설치되어 있지 않습니다.
지금 nodejs.org 다운로드 페이지를 열겠습니다.
설치 후 다시 실행해주세요." buttons {"확인"} default button 1 with icon stop with title "Claw Web — Node.js 필요"' 2>/dev/null || true
    open "https://nodejs.org/ko/download" 2>/dev/null || true
    echo "[preinstall] FAILED: Node.js not found, opened nodejs.org" >> "$LOG"
    exit 1
  fi
fi

NODE_VER=$($NODE_PATH -v | sed 's/v//' | cut -d. -f1)
if [ "$NODE_VER" -lt 20 ]; then
  osascript -e "display dialog \"Node.js 20 이상이 필요합니다.
현재: v$($NODE_PATH -v)
https://nodejs.org 에서 업데이트해주세요.\" buttons {\"확인\"} default button 1 with icon stop with title \"Claw Web\"" 2>/dev/null || true
  echo "[preinstall] FAILED: Node.js too old ($NODE_VER)" >> "$LOG"
  exit 1
fi

echo "[preinstall] Node.js OK: $($NODE_PATH -v)" >> "$LOG"
exit 0
