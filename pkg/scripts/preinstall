#!/bin/bash
# Claw Web — preinstall: 인증번호 확인 + Node.js 체크
set -e
LOG="/tmp/claw-web-install.log"
echo "[preinstall] $(date)" >> "$LOG"

# ═══════════════════════════════════════════════
# 1. 인증번호 입력 (공란 거부)
# ═══════════════════════════════════════════════
# Google Sheets A열에 등록된 인증번호 중 하나를 입력해야 설치 진행.
# 시트가 "웹에 게시 (CSV)" 되면 실제 값 대조 가능. 현재는 공란만 거부.

LICENSE=$(osascript 2>/dev/null <<'OSA'
try
  set dlg to display dialog "Claw Web 설치 인증번호를 입력하세요.

Google Sheets A열의 인증번호 중 하나를 입력해주세요.
(공란은 허용되지 않습니다)" default answer "" with title "Claw Web — 인증번호 확인" buttons {"취소", "설치 계속"} default button 2 with icon note
  return text returned of dlg
on error
  return ""
end try
OSA
)

# trim whitespace
LICENSE_TRIM=$(echo "$LICENSE" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

if [ -z "$LICENSE_TRIM" ]; then
  osascript -e 'display dialog "인증번호가 비어있거나 취소되었습니다.
설치를 중단합니다." buttons {"확인"} default button 1 with icon stop with title "Claw Web — 설치 취소"' 2>/dev/null || true
  echo "[preinstall] FAILED: empty/cancelled license" >> "$LOG"
  exit 1
fi

# 인증번호 기록 (향후 서버 검증 시 참조용)
mkdir -p /var/db 2>/dev/null || true
echo "$LICENSE_TRIM" > /var/db/claw-web-license.txt 2>/dev/null || true
chmod 644 /var/db/claw-web-license.txt 2>/dev/null || true
echo "[preinstall] license recorded (${#LICENSE_TRIM} chars)" >> "$LOG"

# ═══════════════════════════════════════════════
# 2. Node.js 확인
# ═══════════════════════════════════════════════
NODE_PATH=""
for p in /usr/local/bin/node /opt/homebrew/bin/node; do
  if [ -x "$p" ]; then NODE_PATH="$p"; break; fi
done

if [ -z "$NODE_PATH" ]; then
  osascript -e 'display dialog "Node.js가 설치되어 있지 않습니다.
https://nodejs.org 에서 먼저 설치해주세요." buttons {"확인"} default button 1 with icon stop with title "Claw Web"' 2>/dev/null || true
  echo "[preinstall] FAILED: Node.js not found" >> "$LOG"
  exit 1
fi

NODE_VER=$($NODE_PATH -v | sed 's/v//' | cut -d. -f1)
if [ "$NODE_VER" -lt 20 ]; then
  osascript -e "display dialog \"Node.js 20 이상이 필요합니다.
현재: v$($NODE_PATH -v)
https://nodejs.org 에서 업데이트해주세요.\" buttons {\"확인\"} default button 1 with icon stop with title \"Claw Web\"" 2>/dev/null || true
  echo "[preinstall] FAILED: Node.js too old ($NODE_VER)" >> "$LOG"
  exit 1
fi

echo "[preinstall] Node.js OK: $($NODE_PATH -v)" >> "$LOG"
exit 0
